FROM node:18-alpine


WORKDIR /app


# Install pnpm
RUN npm install -g pnpm


# Copy ONLY root workspace config
COPY package.json pnpm-workspace.yaml ./


# Copy ONLY this service's package.json (not all services)
COPY services/search-and-discovery/package.json ./services/search-and-discovery/package.json


# Install ONLY this service's dependencies
RUN pnpm install --filter search-and-discovery --shamefully-hoist


# Copy ONLY this service's source
COPY services/search-and-discovery ./services/search-and-discovery/


WORKDIR /app/services/search-and-discovery


EXPOSE 4003


CMD ["../../node_modules/.bin/ts-node-dev", "--respawn", "--transpile-only", "--exit-child", "src/index.ts"]
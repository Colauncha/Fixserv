# CMD ["npx", "ts-node-dev", "--poll", "--transpile-only", "src/index.ts"]

FROM node:18-alpine

WORKDIR /app

# Install pnpm
RUN npm install -g pnpm

# Copy ONLY root workspace config
COPY package.json pnpm-workspace.yaml ./

# Copy ONLY this service's package.json (not all services)
COPY services/user-management/package.json ./services/user-management/package.json

# Install ONLY this service's dependencies
RUN pnpm install --filter user-management --shamefully-hoist

# Copy ONLY this service's source
COPY services/user-management ./services/user-management/

WORKDIR /app/services/user-management

EXPOSE 4000

CMD ["../../node_modules/.bin/ts-node-dev", "--respawn", "--transpile-only", "--exit-child", "src/index.ts"]
FROM node:18-alpine


WORKDIR /app


# Install pnpm
RUN npm install -g pnpm


# Copy ONLY root workspace config
COPY package.json pnpm-workspace.yaml ./


# Copy ONLY this service's package.json (not all services)
COPY services/wallet-service/package.json ./services/wallet-service/package.json


# Install ONLY this service's dependencies
RUN pnpm install --filter wallet-service --shamefully-hoist


# Copy ONLY this service's source
COPY services/wallet-service ./services/wallet-service/


WORKDIR /app/services/wallet-service


EXPOSE 4005


CMD ["../../node_modules/.bin/ts-node-dev", "--respawn", "--transpile-only", "--exit-child", "src/index.ts"]